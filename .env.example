# ─── Required ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ─── Optional ────────────────────────────────────────────────
# HTTP server port (default: 8888)
NEUROFLOW_PORT=8888

# SQLite database path (default: /data/neuroflow.db)
NEUROFLOW_DB_PATH=/data/neuroflow.db

# API key for HTTP endpoints (empty = no auth)
NEUROFLOW_API_KEY=

# Polling interval in seconds (default: 5)
NEUROFLOW_POLL_INTERVAL=5

# Segment thresholds (days)
NEUROFLOW_COLD_DAYS=7
NEUROFLOW_CHURN_DAYS=30

# Allowed chat IDs (comma-separated, empty = all)
NEUROFLOW_ALLOWED_CHATS=

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
NEUROFLOW_LOG_LEVEL=INFO
